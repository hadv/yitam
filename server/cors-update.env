# CORS Configuration Update
# This change allows both www.yitam.org and yitam.org origins
# Replace the current CLIENT_URL with this array format

# Before:
# CLIENT_URL=https://yitam.org

# After:
CLIENT_URL=https://yitam.org,https://www.yitam.org

# Note: Update this in your server's .env file and restart the server
# The socket.io config will automatically use this for CORS configuration
